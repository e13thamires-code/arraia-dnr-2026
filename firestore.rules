rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // === Arraiá DNR 2026 ===
    // Libera SÓ a "gaveta" do arraiá (coleção arraia2026). Festa entre amigos:
    // qualquer pessoa com o link pode confirmar presença, votar, sugerir e deixar recado.
    // Trava sozinho em 31/08/2026 (depois da festa). O resto do projeto NÃO é afetado.
    match /arraia2026/{document=**} {
      allow read, write: if request.time < timestamp.date(2026, 8, 31);
    }

  }
}
